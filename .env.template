# ── Mode ──────────────────────────────────────────────────────────────────────
# DRY_RUN (default): write operations return what *would* happen
# EXECUTE: write operations actually run
WORKGRAPH_MODE=DRY_RUN

# Set to true for mock data (no real API calls)
MOCK_MODE=false

# ── Jira ─────────────────────────────────────────────────────────────────────
JIRA_BASE_URL=https://your-instance.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_TOKEN=your-api-token
# JIRA_API_VERSION=3  # 2 for Server/DC, 3 for Cloud (default)

# ── Bitbucket ────────────────────────────────────────────────────────────────
BITBUCKET_BASE_URL=https://api.bitbucket.org
BITBUCKET_WORKSPACE=your-workspace
BITBUCKET_USERNAME=your-username
BITBUCKET_APP_PASSWORD=your-app-password

# ── Confluence ───────────────────────────────────────────────────────────────
CONFLUENCE_BASE_URL=https://your-instance.atlassian.net/wiki
CONFLUENCE_EMAIL=your-email@example.com
CONFLUENCE_TOKEN=your-api-token

# ── Bamboo ───────────────────────────────────────────────────────────────────
BAMBOO_BASE_URL=https://your-bamboo.example.com
BAMBOO_USERNAME=your-username
BAMBOO_TOKEN=your-token

# ── Allowlists (comma-separated, empty = allow all) ─────────────────────────
# ALLOWLIST_JIRA_PROJECT_KEYS=PROJ1,PROJ2
# ALLOWLIST_BITBUCKET_REPOS=repo1,repo2
# ALLOWLIST_CONFLUENCE_SPACE_KEYS=SPACE1,SPACE2
# ALLOWLIST_BAMBOO_PLANS=PLAN1,PLAN2

# ── MCP Server ───────────────────────────────────────────────────────────────
# MCP_TRANSPORT=stdio          # stdio (default) or streamable-http
# MCP_HOST=127.0.0.1
# MCP_PORT=8000

# ── Logging ──────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
# LOG_FILE=
# AUDIT_LOG_PATH=audit.log.jsonl
